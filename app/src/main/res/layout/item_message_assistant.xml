<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="56dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- AI avatar -->
    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:src="@drawable/ic_ai_avatar"
        android:contentDescription="AI" />

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_assistant">

        <TextView
            android:id="@+id/tv_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textColor="@color/on_surface"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.4"
            android:visibility="gone" />

        <!-- Loading dots animation -->
        <LinearLayout
            android:id="@+id/loading_dots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical"
            android:visibility="visible">

            <View android:id="@+id/dot1"
                android:layout_width="8dp" android:layout_height="8dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_dot" />
            <View android:id="@+id/dot2"
                android:layout_width="8dp" android:layout_height="8dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_dot" />
            <View android:id="@+id/dot3"
                android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_dot" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
